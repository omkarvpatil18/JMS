% ===================================================================
% rules.lp  —  Stable rule template for constrained shortest-path
%              manufacturing execution planning (Listing 1, Section 3.3.2)
%
% Authors : Omkar Vishwas Patil, Kushal Bhandari, Omid Fatahi Valilai
% Journal : Journal of Manufacturing Systems (JMS), Elsevier
% Paper   : A Cyber-Physical Manufacturing Execution Architecture
%           Integrating ERP Transaction Automation and Autonomous
%           Decision-Making
% Solver  : clingo 5.8.0 (Potsdam Answer Set Solving Collection)
%
% Usage   : clingo rules.lp instance.lp --opt-mode=opt -n 1
%
% Instance facts expected (generated by ERP execution pipeline):
%   node(V)       — node V in the manufacturing execution network
%   edge(I,J)     — directed lane (I,J) is feasible
%   cost(I,J,C)   — arc cost C for lane (I,J)
%   cap(I,J,U)    — arc capacity U for lane (I,J)  [optional]
%   ship(K,O,D,Q) — shipment K from origin O to destination D, demand Q
% ===================================================================

% ===== Decision predicate =====
{ use(K,I,J) : edge(I,J) } :- ship(K,O,D,Q).

% ===== Reachability (path construction) =====
reach(K,O) :- ship(K,O,D,Q).
reach(K,J) :- reach(K,I), use(K,I,J).
:- ship(K,O,D,Q), not reach(K,D).

% ===== Flow conservation =====
1 { use(K,O,J) : edge(O,J) } 1 :- ship(K,O,D,Q).
:- ship(K,O,D,Q), use(K,I,O), edge(I,O).

1 { use(K,I,D) : edge(I,D) } 1 :- ship(K,O,D,Q).
:- ship(K,O,D,Q), use(K,D,J), edge(D,J).

in(K,V)  :- use(K,I,V), edge(I,V).
out(K,V) :- use(K,V,J), edge(V,J).

% balanced in/out-degree at intermediate nodes
:- node(V), ship(K,O,D,Q), V != O, V != D,
   in(K,V), not out(K,V).

:- node(V), ship(K,O,D,Q), V != O, V != D,
   out(K,V), not in(K,V).

% prevent multi-arc entry/exit at intermediate nodes
:- node(V), ship(K,O,D,Q), V != O, V != D,
   2 { use(K,I,V) : edge(I,V) }.

:- node(V), ship(K,O,D,Q), V != O, V != D,
   2 { use(K,V,J) : edge(V,J) }.

% prevent immediate backtracking
:- ship(K,O,D,Q), use(K,I,J), use(K,J,I), I != J.

% ===== Capacity constraints (optional) =====
:- cap(I,J,U),
   U < #sum { Q,K : ship(K,O,D,Q), use(K,I,J) }.

% ===== Objective =====
#minimize { C,K,I,J : use(K,I,J), cost(I,J,C) }.

% ===== Output projection =====
#show use/3.
